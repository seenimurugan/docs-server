# ---------------------------------------------------------------------------
# docs-server — environment variables
# Copy this file to .env, adjust values if needed, then run ./deploy.sh
# ---------------------------------------------------------------------------

# ── Kubernetes ───────────────────────────────────────────────────────────────
# Namespace to deploy into (must exist — homelab-cluster-setup creates it)
HOMELAB_NAMESPACE=homelab

# ── Mode ─────────────────────────────────────────────────────────────────────
# gitsync  — (default) git-puller sidecar; auto-discovers seenimurugan/* repos
# hostpath — legacy mode; mounts DOCS_HOST_PATH directly (no GitHub needed)
DOCS_SOURCE=gitsync

# ── gitsync settings (used only if DOCS_SOURCE=gitsync) ─────────────────────
GITHUB_USER=seenimurugan
SYNC_INTERVAL_SECONDS=300
# NOTE: GITHUB_TOKEN is NOT in .env — it is extracted from `gh auth token`
# at deploy time.  No manual PAT management needed.
# If you re-authenticate with gh, just re-run ./deploy.sh to refresh the secret.

# ── hostpath settings (used only if DOCS_SOURCE=hostpath) ────────────────────
# Absolute path on the host node where your docs folder lives.
DOCS_HOST_PATH=/Users/nila/Developer/agents/docs

# ── nginx image ──────────────────────────────────────────────────────────────
NGINX_IMAGE=nginx
NGINX_TAG=alpine
